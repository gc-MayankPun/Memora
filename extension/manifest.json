{
  "manifest_version": 3,
  "name": "Memora",
  "version": "2.0",
  "description": "Save anything from the web. Recall it later.",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },

  "permissions": ["activeTab", "storage", "tabs"],

  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://localhost:5000/*",
    "http://localhost:3000/*",
    "https://memora-01wh.onrender.com/*"
  ],

  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "memora@yourdomain.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["websiteActivity", "websiteContent"],
        "optional": []
      }
    }
  }, 

  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  }
}